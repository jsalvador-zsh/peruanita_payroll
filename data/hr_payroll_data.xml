<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Secuencia para Planilla -->
        <record id="seq_hr_payroll_monthly" model="ir.sequence">
            <field name="name">Planilla Mensual</field>
            <field name="code">hr.payroll.monthly</field>
            <field name="prefix">PL/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Datos de AFP -->
        <record id="afp_integra" model="hr.afp.pension">
            <field name="name">Integra</field>
            <field name="code">IN</field>
            <field name="fund_percentage">10.00</field>
            <field name="insurance_percentage">1.74</field>
            <field name="commission_percentage">0.90</field>
            <field name="commission_type">mixed</field>
        </record>

        <record id="afp_prima" model="hr.afp.pension">
            <field name="name">Prima</field>
            <field name="code">PR</field>
            <field name="fund_percentage">10.00</field>
            <field name="insurance_percentage">1.74</field>
            <field name="commission_percentage">1.25</field>
            <field name="commission_type">flow</field>
        </record>

        <record id="afp_profuturo" model="hr.afp.pension">
            <field name="name">Profuturo</field>
            <field name="code">PF</field>
            <field name="fund_percentage">10.00</field>
            <field name="insurance_percentage">1.74</field>
            <field name="commission_percentage">1.20</field>
            <field name="commission_type">mixed</field>
        </record>

        <record id="afp_habitat" model="hr.afp.pension">
            <field name="name">Habitat</field>
            <field name="code">HB</field>
            <field name="fund_percentage">10.00</field>
            <field name="insurance_percentage">1.74</field>
            <field name="commission_percentage">1.25</field>
            <field name="commission_type">mixed</field>
        </record>
    </data>
</odoo>